# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Tailscale API (tailnet device list) ────────────────────────────────────────
# Create an OAuth client at https://login.tailscale.com/admin/settings/oauth
# with the "devices:core" (read) scope.
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_TAILNET=-

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL where TS-RX is reachable (used in notification links)
APP_URL=https://your-domain.com

# ── Notifications (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_FROM=noreply@your-domain.com
