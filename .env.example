VITE_API_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/analysis_agent
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Create an OAuth client at https://login.tailscale.com/admin/settings/oauth
# with the "devices:core" (read) scope.
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_TAILNET=-
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SEC=1.5
ALLOWED_READ_ROOTS=src,services,config
MAX_LOG_SNIPPETS=150
MAX_LOG_LINE_CHARS=600
MAX_CONTEXT_FILES=8
MAX_CONTEXT_EXCERPT_CHARS=1600
